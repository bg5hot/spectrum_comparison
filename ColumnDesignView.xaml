<UserControl x:Class="SpectrumComparison.ColumnDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpectrumComparison"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <local:ColumnDesignViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource FluentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Side: Inputs -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="ACI 318 矩形柱截面设计" Style="{StaticResource SectionTitleStyle}"/>
               
                
                <!-- 1. Dimensions -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. 截面尺寸" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="宽度 b (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding B, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="高度 h (in):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding H, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="保护层 cc (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Cover, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Materials -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. 材料信息" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="混凝土 f'c (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Fc, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="钢筋 fy (psi):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Fy, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Reinforcement -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3. 配筋信息" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纵筋规格:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding BarSizeOptions}" SelectedItem="{Binding SelectedBarSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="箍筋规格:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding BarSizeOptions}" SelectedItem="{Binding SelectedTieSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="宽度方向纵筋数量:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding BarCountOptions}" SelectedItem="{Binding Nx}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="高度方向纵筋数量:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding BarCountOptions}" SelectedItem="{Binding Ny}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3"/>
                        </Grid>
                                                <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="X向箍筋肢数:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding TieLegOptions}" SelectedItem="{Binding TieLegsX}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="Y向箍筋肢数:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding TieLegOptions}" SelectedItem="{Binding TieLegsY}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 4. Loads -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="4. 设计荷载" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                         <TextBlock Text="注意：Mux为绕X轴弯矩，Muy为绕Y轴弯矩" FontSize="12" Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="轴力 Pu (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Pu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="弯矩 Mux (k-ft):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Mux, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="弯矩 Muy (k-ft):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Muy, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="剪力 Vuy (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Vuy, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="剪力 Vux (kips):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Vux, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Calculate Button -->
                <Button Content="执行验算" Command="{Binding CalculateCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                <!-- Section Preview -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="SECTION PREVIEW" 
                                   Style="{StaticResource StrongLabelStyle}" 
                                   HorizontalAlignment="Center" 
                                   Foreground="#667085" 
                                   Margin="0,0,0,16"/>
                        
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Height Label -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="{Binding H, StringFormat='{}{0:F0}&quot;'}" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,8,0"
                                       Foreground="#475467">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="-90"/>
                                </TextBlock.LayoutTransform>
                            </TextBlock>

                            <!-- Preview -->
                            <Viewbox Grid.Row="0" Grid.Column="1" Height="150" Margin="10">
                                <Grid Width="{Binding B}" Height="{Binding H}">
                                    <!-- Concrete Section -->
                                    <Rectangle Stroke="#475467" StrokeThickness="0.2" Fill="#EAEFF5"/>
                                    
                                    <!-- Tie (Approximate visual) -->
                                    <Rectangle Margin="{Binding Cover}" Stroke="#475467" StrokeThickness="0.1" RadiusX="0.5" RadiusY="0.5"/>
                                    
                                    <!-- Rebar -->
                                    <ItemsControl ItemsSource="{Binding RebarLocations}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="1" Height="1" Fill="#101828">
                                                    <Ellipse.RenderTransform>
                                                        <TranslateTransform X="-0.5" Y="-0.5"/>
                                                    </Ellipse.RenderTransform>
                                                </Ellipse>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>

                            <!-- Width Label -->
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding B, StringFormat='{}{0:F0}&quot;'}" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,4,0,8"
                                       Foreground="#475467"/>

                            <!-- Bar Info -->
                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                       Text="{Binding RebarInfo}" 
                                       HorizontalAlignment="Center" 
                                       FontWeight="Bold" 
                                       Foreground="#475467"
                                       FontSize="14"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Side: Chart & Results -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top: P-M Charts in TabControl -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="0">
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </TabControl.Resources>
                    
                    <TabItem Header="P-Mx 相互作用曲线">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- <TextBlock Text="P-Mx 相互作用曲线" Style="{StaticResource StrongLabelStyle}" Margin="0,0,0,8"/> -->
                            
                            <lvc:CartesianChart Grid.Row="1"
                                                Series="{Binding SeriesX}"
                                                XAxes="{Binding XAxesX}"
                                                YAxes="{Binding YAxesX}"
                                                ZoomMode="Both"
                                                LegendPosition="Right">
                            </lvc:CartesianChart>
                        </Grid>
                    </TabItem>

                    <TabItem Header="P-My 相互作用曲线">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- <TextBlock Text="P-My 相互作用曲线" Style="{StaticResource StrongLabelStyle}" Margin="0,0,0,8"/> -->
                            
                            <lvc:CartesianChart Grid.Row="1"
                                                Series="{Binding SeriesY}"
                                                XAxes="{Binding XAxesY}"
                                                YAxes="{Binding YAxesY}"
                                                ZoomMode="Both"
                                                LegendPosition="Right">
                            </lvc:CartesianChart>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- Bottom: Text Report -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="验算报告" Style="{StaticResource StrongLabelStyle}" Margin="0,0,0,8"/>
                    
                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="{StaticResource FluentBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                        <TextBox Text="{Binding DesignProcess}" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
