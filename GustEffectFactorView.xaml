<UserControl x:Class="SpectrumComparison.GustEffectFactorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpectrumComparison"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200">

    <UserControl.DataContext>
        <local:GustEffectFactorViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource FluentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：输入参数 -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="ASCE 7-16 阵风响应因子 Gust-Effect Factor计算" Style="{StaticResource SectionTitleStyle}"/>
                
                <!-- 场地参数 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="场地参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="场地类别 Exposure (B/C/D):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding ExposureOptions}" SelectedItem="{Binding Exposure}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 建筑尺寸 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="建筑尺寸" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="高度 h (m):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding BuildingHeight, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="宽度 B (m):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding BuildingWidth, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="深度 L (m):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding BuildingDepth, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 风和结构参数 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="风和结构参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="基本风速 V (m/s):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding WindSpeed, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="结构一阶频率n₁(Hz):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding NaturalFrequency, StringFormat=F3}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="结构阻尼比 β: " Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Beta, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 计算按钮 -->
                <Button Content="计算阵风响应因子 Gust-Effect Factor" Command="{Binding CalculateCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                <!-- 结果显示 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="计算结果" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="{Binding BuildingType}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" FontWeight="Medium"/>
                        
                        <Border Background="{StaticResource FluentBlueBrush}" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                            <TextBlock Text="{Binding GustEffectFactor}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        
                        <Separator Style="{StaticResource SeparatorStyle}"/>
                        
                        <TextBlock Text="中间计算结果:" Style="{StaticResource StrongLabelStyle}" FontSize="12" Margin="0,8,0,8" Foreground="#666666"/>
                        
                        <TextBlock Text="{Binding QValue}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding RValue}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 右侧：计算过程 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="详细计算过程" Style="{StaticResource SectionTitleStyle}"/>
                
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="ASCE 7-16 Section 26.11 计算步骤:" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" Grid.Row="0"/>
                        <Border Background="#F5F5F5" BorderBrush="{StaticResource FluentBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Grid.Row="1">
                            <TextBox Text="{Binding ProcessText}" 
                                     IsReadOnly="True" 
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="500"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="14"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
