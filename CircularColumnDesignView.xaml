<UserControl x:Class="SpectrumComparison.CircularColumnDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpectrumComparison"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <local:CircularColumnDesignViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource FluentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Side: Inputs -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="ACI 318 圆形柱截面设计" Style="{StaticResource SectionTitleStyle}"/>
               
                <!-- 1. Dimensions -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="1. 截面尺寸" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="直径 D (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Diameter, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="保护层 cc (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Cover, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Materials -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. 材料信息" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="混凝土 f'c (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Fc, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="钢筋 fy (psi):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Fy, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Reinforcement -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3. 配筋信息" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纵筋规格:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding BarSizes}" SelectedItem="{Binding SelectedBarSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="箍筋规格:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding BarSizes}" SelectedItem="{Binding SelectedTieSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3"/>
                        </Grid>
                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="纵筋根数:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding NumBarsOptions}" SelectedItem="{Binding NumBars}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>
                         <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="箍筋形式:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding TieTypes}" SelectedItem="{Binding SelectedTieType}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 4. Loads -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="4. 设计荷载" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="轴力 Pu (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Pu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="弯矩 Mux (k-ft):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Mux, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                             <TextBlock Text="弯矩 Muy (k-ft):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Muy, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                         <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="剪力 Vux (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Vux, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                             <TextBlock Text="剪力 Vuy (kips):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Vuy, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="执行设计验算" Command="{Binding CalculateCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,8,0,16"/>

                <!-- Rebar Preview -->
                <Border Style="{StaticResource CardStyle}" Height="300">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="截面预览" Style="{StaticResource StrongLabelStyle}"/>
                        
                        <Viewbox Grid.Row="1" Margin="20">
                            <Grid Width="{Binding Diameter}" Height="{Binding Diameter}">
                                <!-- Concrete Outline -->
                                <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}" 
                                         Fill="#E5E5E5" Stroke="Gray" StrokeThickness="1"/>
                                
                                <!-- Rebar Points -->
                                <ItemsControl ItemsSource="{Binding RebarLocations}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="{Binding VisualSize}" Height="{Binding VisualSize}" Fill="Red"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>
                        
                        <TextBlock Text="{Binding RebarInfo}" Grid.Row="2" 
                                   HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Right Side: Charts & Report -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- Charts -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="P-Mx 相互作用曲线">
                        <Grid Margin="8">
                            <lvc:CartesianChart Series="{Binding SeriesX}"
                                                XAxes="{Binding XAxesX}"
                                                YAxes="{Binding YAxesX}"
                                                ZoomMode="Both"
                                                LegendPosition="Right"/>
                        </Grid>
                    </TabItem>
                     <TabItem Header="P-My 相互作用曲线">
                        <Grid Margin="8">
                            <lvc:CartesianChart Series="{Binding SeriesY}"
                                                XAxes="{Binding XAxesY}"
                                                YAxes="{Binding YAxesY}"
                                                ZoomMode="Both"
                                                LegendPosition="Right"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- Report -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="设计计算书" Style="{StaticResource StrongLabelStyle}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" Text="{Binding DesignProcess}" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
