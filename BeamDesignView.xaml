<UserControl x:Class="SpectrumComparison.BeamDesignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpectrumComparison"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200">

    <UserControl.DataContext>
        <local:BeamDesignViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource FluentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：输入参数 -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16">
            <StackPanel>
                <TextBlock Text="ACI 318 单筋梁截面设计" Style="{StaticResource SectionTitleStyle}"/>
                
                <!-- 材料参数 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="材料参数" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="混凝土 f'c (psi):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Fc, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="钢筋 fy (psi):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Fy, StringFormat=F0}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 截面尺寸 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="截面尺寸" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="宽度 b (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding B, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="高度 h (in):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding H, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="保护层 (in):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Cover, StringFormat=F2}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="箍筋直径 (in):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding StirrupDiameter, StringFormat=F3}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 荷载 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="设计荷载" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="弯矩 Mu (kip-ft):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Mu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="剪力 Vu (kips):" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <TextBox Text="{Binding Vu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="3"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="轴力 Nu (kips):" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <TextBox Text="{Binding Nu, StringFormat=F1}" Style="{StaticResource FluentNumericStyle}" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 钢筋选择 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="钢筋选择" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="受拉钢筋:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding BarSizeOptions}" SelectedItem="{Binding SelectedBarSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="1" Margin="0,0,8,0"/>
                            <TextBlock Text="箍筋:" Style="{StaticResource LabelStyle}" Grid.Column="2"/>
                            <ComboBox ItemsSource="{Binding StirrupSizeOptions}" SelectedItem="{Binding SelectedStirrupSize}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="3" Margin="0,0,8,0"/>
                            <TextBlock Text="肢数:" Style="{StaticResource LabelStyle}" Grid.Column="4"/>
                            <ComboBox ItemsSource="{Binding StirrupLegOptions}" SelectedItem="{Binding StirrupLegs}" 
                                      Style="{StaticResource FluentComboBoxStyle}" Grid.Column="5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 计算按钮 -->
                <Button Content="执行设计" Command="{Binding CalculateCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                <!-- 结果显示 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="设计结果" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="{Binding RequiredSteelArea}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ProvidedSteelArea}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding NumberOfBars}" Style="{StaticResource StrongLabelStyle}" Margin="0,0,0,8"/>
                        
                        <Separator Style="{StaticResource SeparatorStyle}"/>
                        
                        <TextBlock Text="{Binding PhiMnResult}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding MomentRatio}" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SectionType}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                        
                        <TextBlock Text="{Binding DesignStatus}" Style="{StaticResource StrongLabelStyle}" FontSize="14" Margin="0,0,0,8"/>
                        
                        <Separator Style="{StaticResource SeparatorStyle}"/>
                        
                        <TextBlock Text="{Binding ShearResult}" Style="{StaticResource LabelStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 右侧：设计过程与截面预览 -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="详细计算过程" Style="{StaticResource SectionTitleStyle}"/>
                    
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="ACI 318-25 计算步骤:" Style="{StaticResource LabelStyle}" Margin="0,0,0,8" Grid.Row="0"/>
                            <Border Background="#F5F5F5" BorderBrush="{StaticResource FluentBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Grid.Row="1">
                                <TextBox Text="{Binding DesignProcess}" 
                                         IsReadOnly="True" 
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="400"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="14"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Section Preview -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="SECTION PREVIEW" 
                               Style="{StaticResource StrongLabelStyle}" 
                               HorizontalAlignment="Center" 
                               Foreground="#667085" 
                               Margin="0,0,0,16"/>
                    
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Height Label -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="{Binding H, StringFormat='{}{0:F0}&quot;'}" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,8,0"
                                   Foreground="#475467">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>

                        <!-- Preview -->
                        <Viewbox Grid.Row="0" Grid.Column="1" Height="150" Margin="10">
                            <Grid Width="{Binding B}" Height="{Binding H}">
                                <!-- Concrete Section -->
                                <Rectangle Stroke="#475467" StrokeThickness="0.2" Fill="#EAEFF5"/>
                                
                                <!-- Stirrup (Approximate visual) -->
                                <Rectangle Margin="{Binding Cover}" Stroke="#475467" StrokeThickness="0.1" RadiusX="{Binding StirrupDiameter}" RadiusY="{Binding StirrupDiameter}"/>
                                
                                <!-- Rebar -->
                                <ItemsControl ItemsSource="{Binding RebarLocations}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="1" Height="1" Fill="#101828">
                                                <Ellipse.RenderTransform>
                                                    <TranslateTransform X="-0.5" Y="-0.5"/>
                                                </Ellipse.RenderTransform>
                                            </Ellipse>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>

                        <!-- Width Label -->
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                   Text="{Binding B, StringFormat='{}{0:F0}&quot;'}" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,4,0,8"
                                   Foreground="#475467"/>

                        <!-- Bar Info -->
                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                   Text="{Binding RebarInfo}" 
                                   HorizontalAlignment="Center" 
                                   FontWeight="Bold" 
                                   Foreground="#475467"
                                   FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
